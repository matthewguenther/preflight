# === Frontend (VITE_ prefix exposes to browser) ===
# Optional: pin a default airport for first-time visitors. Leave blank to show
# a search prompt on first load (returning visitors resume their last airport).
VITE_AIRPORT_ICAO=
VITE_API_AUTH_TOKEN=

# === Functions only (server-side, never exposed) ===
API_AUTH_TOKEN=
FAA_NOTAM_CLIENT_ID=
FAA_NOTAM_CLIENT_SECRET=

# === Optional - only if Flight Schedule Pro API access granted ===
FSP_API_KEY=
FSP_CLUB_ID=
